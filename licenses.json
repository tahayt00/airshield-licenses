-- Haalt de actie op: 'ban' of 'kick'
function getEnforcementAction(reason)
    local defaultAction = "ban"
    local configKey = reasonToConfigKey[reason]
    if configKey and Config.EnforcementActions and Config.EnforcementActions[configKey] then
        return Config.EnforcementActions[configKey]
    end
    if Config.EnforcementActions and Config.EnforcementActions[reason] then
        return Config.EnforcementActions[reason]
    end
    return defaultAction
end

function shouldBan(playerId, src, reason)
    local whitelistskipTimeCheckReasons = {
        ["Susano Menu Detected"] = true,
        ["Anti Ai Explosion"] = true
    }

    if whitelistskipTimeCheckReasons[reason] then
        return true
    end

    -- Check if invoking resource is full whitelisted (like admin)
    local invokingResource = GetInvokingResource()
    if invokingResource and isResourceFullWhitelisted(invokingResource) then
        return false -- Full whitelisted resource, bypass all checks like admin
    end

    if isExempt(playerId) then return false end
    if isExemptserver(src) then return false end
    if IsPlayerAdmin(src) then return false end
    return true
end


function banPlayer(playerId, reason)
    local numericPlayerId = tonumber(playerId)
    if not numericPlayerId then return end

    -- CRITICAL: ALWAYS allow these reasons even during spawn/loading
    local criticalReasons = {
        ["Susano Menu Detected"] = true,
        ["Explosion detected"] = true,
        ["Ai Explosion Detected"] = true,
        ["Stop Resource Detected"] = true,
        ["Stopping AirShield"] = true,
        ["Identifier Spoofing Detected"] = true,
        ["Prohibited Weapon Spawn Detected"] = true,
        ["Money Exploit Detected"] = true,
        ["Lua script Injection detected"] = true,
        ["Resource Injection Detected"] = true,
        ["TriggerServerEvent Hooking Detected"] = true,
        ["Eulen Freecam Detected"] = true,
        -- Make Throw Vehicle detections immediate-ban
        ["Throw Vehicle Detected"] = true,
        ["Throw Vehicle: Slingshot Attempt"] = true,
        ["Throw Vehicle: Unnatural Impulse Detected"] = true,
        ["Throw Vehicle: Vertical Launch Detected"] = true
    }
    local reasonLower = string.lower(tostring(reason or ""))
    local isCritical = criticalReasons[reason] 
        or reasonLower:find("throw vehicle") ~= nil

    -- 1. Check if player is even in the activeClients list
    if not activeClients[numericPlayerId] and not isCritical then
        return
    end

    -- 2. Strictly enforce playersReady check for everything non-critical
    if not playersReady[numericPlayerId] and not isCritical then
        -- Log that we skipped a ban for an unready player (debug only)
        -- print("^3[AirShield] Skipped detection for player " .. numericPlayerId .. " because they are still loading: " .. reason .. "^0")
        return
    end

    -- 3. Additional Grace Period check (30 seconds after MarkPlayerJoined)
    local joinedTime = joinedAt[numericPlayerId]
    if joinedTime then
        local secondsOnline = os.time() - joinedTime
        local gracePeriod = 30 -- 30 seconds grace period for non-critical detections
        
        if secondsOnline < gracePeriod and not isCritical then
            -- print("^3[AirShield] Skipped detection for player " .. numericPlayerId .. " during 30s grace period: " .. reason .. "^0")
            return
        end
    end

    local action = getEnforcementAction(reason)

    if not shouldBan(numericPlayerId, numericPlayerId, reason) then
        return
    end

    if action == "kick" then
        local name = GetPlayerName(playerId) or "Unknown"
        DropPlayer(playerId, "[AirShield] You were kicked for: " .. reason)
        print('^2[AirShield]^1 | KICK PLAYER ' .. name .. ' ^4WITH REASON ' .. reason)
        return
    end

    if recentBans[playerId] and os.time() - recentBans[playerId] < 6 then
         return
    end
     recentBans[playerId] = os.time()

    -- Check if player is already banned to prevent duplicates
    if IsPlayerAlreadyBanned(playerId) then
        print('^2[AirShield]^1 | SKIPPED BAN FOR PLAYER ' .. (GetPlayerName(playerId) or "Unknown") .. ' ^4(ALREADY BANNED)')
        return
    end

    local src = numericPlayerId

    local identifiers = GetPlayerIdentifiers(playerId)
    local steam, license, ip, hwid = "Onbekend", "Onbekend", "Onbekend", "Onbekend"
    local license2, discord, live, xbl, guid, seed, gameid = "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend"
    local fivem, thor, redm, license3, twitch = "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend"
    local vbl, ros, license4, license5 = "Onbekend", "Onbekend", "Onbekend", "Onbekend"    

    for _, id in ipairs(identifiers) do
        if string.match(id, "steam:") then steam = id end
        if string.match(id, "license:") then license = id end
        if string.match(id, "license2:") then license2 = id end
        if string.match(id, "license3:") then license3 = id end
        if string.match(id, "license4:") then license4 = id end
        if string.match(id, "license5:") then license5 = id end
        if string.match(id, "ip:") then ip = id end
        if string.match(id, "discord:") then discord = id end
        if string.match(id, "live:") then live = id end
        if string.match(id, "xbl:") then xbl = id end
        if string.match(id, "guid:") then guid = id end
        if string.match(id, "seed:") then seed = id end
        if string.match(id, "gameid:") then gameid = id end
        if string.match(id, "fivem:") then fivem = id end
        if string.match(id, "thor:") then thor = id end
        if string.match(id, "redm:") then redm = id end
        if string.match(id, "twitch:") then twitch = id end
        if string.match(id, "vbl:") then vbl = id end
        if string.match(id, "ros:") then ros = id end
    end    

    hwid = GetPlayerToken(playerId, 0) or "Onbekend"

    local tokens = {}
    for i = 0, GetNumPlayerTokens(playerId) - 1 do
        table.insert(tokens, GetPlayerToken(playerId, i))
    end

    local name = GetPlayerName(playerId)
    local tokenFingerprint = table.concat(tokens, "|")
    if not name then 
        print('^2[AirShield]^1 | INVALID PLAYER ID')
        return 
    end

    -- print('^2[AirShield]^1 | BANNED PLAYER '..name..' '..newBanId..' ('..playerId..') ^4WITH REASON '..reason..'')

    local bansFile = LoadResourceFile(GetCurrentResourceName(), "html/ban.json")
    local bans = {}

    if bansFile then
        bans = json.decode(bansFile) or {}
    else
        print("Warning: bans.json not found. A new one will be created.")
    end

    local highestId = 0
    for _, ban in ipairs(bans) do
        if ban and ban.id then
            local banIdStr = tostring(ban.id)
            local idNumber = tonumber(banIdStr:match("Air%-(%d+)$"))
            if idNumber and idNumber > highestId then
                highestId = idNumber
            end
        end
    end

    local newBanId = 'Air-' .. (highestId + 1)

    -- print('^2[AirShield]^1 | BANNED PLAYER '..name.. '('..newBanId..') ^4WITH REASON '..reason..'')

    -- Capture screenshot before banning player
    TriggerClientEvent("AirShield:TakeScreenshot2", numericPlayerId, reason, Config.screenshotWebhook, newBanId)

local data = {
    steam = steam,
    license = license,
    license2 = license2,
    license3 = license3,
    license4 = license4,
    license5 = license5,
    discord = discord,
    live = live,
    xbl = xbl,
    ip = ip,
    guid = guid,
    seed = seed,
    gameid = gameid,
    fivem = fivem,
    redm = redm,
    thor = thor,
    twitch = twitch,
    vbl = vbl,
    ros = ros,
    hardware_id = hwid,
    tokens = tokens,
    token_fingerprint = tokenFingerprint,
    name = name,
    reason = reason,
    id = newBanId,
    screenshot_url = nil, -- Will be updated when screenshot is taken
}  

    print('^2[AirShield]^1 | BANNED PLAYER '..name.. '('..newBanId..') ^4WITH REASON '..reason..'')

    table.insert(bans, data)

    SaveResourceFile(GetCurrentResourceName(), "html/ban.json", json.encode(bans, { indent = true }), -1)

    local r = tostring(reason or ''):lower()
    local logType = nil
    if r:find('explosion') then logType = 'EXPLOSION'
    elseif r:find('teleport') then logType = 'TELEPORT'
    elseif r:find('entity') then logType = 'ENTITY'
    elseif r:find('kill') then logType = 'KILL'
    elseif r:find('weapon') or r:find('unregistered weapon') then logType = 'WEAPON'
    elseif r:find('blacklisted') then logType = 'BLACKLIST' end
    if logType then
        AppendLog(logType, name, playerId, reason, GetPlayerName(src))
    end
    AppendLog('BAN_PLAYER', name, playerId, reason, GetPlayerName(src))

    sendDiscordLog(playerId, reason, newBanId)
    sendDiscordLogbanlogs(playerId, reason)

    -- Move player to separate routing bucket (Other World)
    SetPlayerRoutingBucket(playerId, 999)

local kickMessage = string.format(
    "\n[AirShield] %s\n%s\n%s",
    _L("banKickHeader") or "You have been banned by our automatic system",
    _L("banKickDuration") or "This ban never expires.",
    _L("banKickReconnect") or "Reconnect for the ban details"
)

Citizen.SetTimeout(4500, function()
    DropPlayer(playerId, kickMessage)
    recentBans[playerId] = nil
end)
end

-- Function to check if a player is already banned
function IsPlayerAlreadyBanned(playerId)
    local bansFile = LoadResourceFile(GetCurrentResourceName(), "html/ban.json")
    local bans = {}
    
    if bansFile then
        bans = json.decode(bansFile) or {}
    else
        return false
    end
    
    local identifiers = GetPlayerIdentifiers(playerId)
    if not identifiers or #identifiers == 0 then
        return false
    end

    local steam, license, ip = "Onbekend", "Onbekend", "Onbekend"
    local license2, license3, license4, license5 = "Onbekend", "Onbekend", "Onbekend", "Onbekend"
    local discord, live, xbl, guid, seed, gameid = "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend"
    local fivem, thor, redm, twitch, vbl, ros = "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend", "Onbekend"
    for _, v in ipairs(identifiers) do
        if v:find("steam:") then steam = v end
        if v:find("license:") then license = v end
        if v:find("license2:") then license2 = v end
        if v:find("license3:") then license3 = v end
        if v:find("license4:") then license4 = v end
        if v:find("license5:") then license5 = v end
        if v:find("ip:") then ip = v end
        if v:find("discord:") then discord = v end
        if v:find("live:") then live = v end
        if v:find("xbl:") then xbl = v end
        if v:find("guid:") then guid = v end
        if v:find("seed:") then seed = v end
        if v:find("gameid:") then gameid = v end
        if v:find("fivem:") then fivem = v end
        if v:find("thor:") then thor = v end
        if v:find("redm:") then redm = v end
        if v:find("twitch:") then twitch = v end
        if v:find("vbl:") then vbl = v end
        if v:find("ros:") then ros = v end
    end

    local tokenCount = GetNumPlayerTokens(playerId)
    local tokens = {}
    for i = 0, tokenCount - 1 do
        tokens[#tokens+1] = GetPlayerToken(playerId, i)
    end
    local hardware_id = GetPlayerToken(playerId, 0) or "Onbekend"
    local token_fingerprint = table.concat(tokens, "|")

    for _, ban in ipairs(bans) do
        local matches = 0
        if ban.steam and ban.steam ~= "Onbekend" and ban.steam == steam then matches = matches + 1 end
        if ban.license and ban.license ~= "Onbekend" and ban.license == license then matches = matches + 1 end
        if ban.license2 and ban.license2 ~= "Onbekend" and ban.license2 == license2 then matches = matches + 1 end
        if ban.license3 and ban.license3 ~= "Onbekend" and ban.license3 == license3 then matches = matches + 1 end
        if ban.license4 and ban.license4 ~= "Onbekend" and ban.license4 == license4 then matches = matches + 1 end
        if ban.license5 and ban.license5 ~= "Onbekend" and ban.license5 == license5 then matches = matches + 1 end
        if ban.ip and ban.ip ~= "Onbekend" and ban.ip == ip then matches = matches + 1 end
        if ban.discord and ban.discord ~= "Onbekend" and ban.discord == discord then matches = matches + 1 end
        if ban.live and ban.live ~= "Onbekend" and ban.live == live then matches = matches + 1 end
        if ban.xbl and ban.xbl ~= "Onbekend" and ban.xbl == xbl then matches = matches + 1 end
        if ban.guid and ban.guid ~= "Onbekend" and ban.guid == guid then matches = matches + 1 end
        if ban.seed and ban.seed ~= "Onbekend" and ban.seed == seed then matches = matches + 1 end
        if ban.gameid and ban.gameid ~= "Onbekend" and ban.gameid == gameid then matches = matches + 1 end
        if ban.fivem and ban.fivem ~= "Onbekend" and ban.fivem == fivem then matches = matches + 1 end
        if ban.thor and ban.thor ~= "Onbekend" and ban.thor == thor then matches = matches + 1 end
        if ban.redm and ban.redm ~= "Onbekend" and ban.redm == redm then matches = matches + 1 end
        if ban.twitch and ban.twitch ~= "Onbekend" and ban.twitch == twitch then matches = matches + 1 end
        if ban.vbl and ban.vbl ~= "Onbekend" and ban.vbl == vbl then matches = matches + 1 end
        if ban.ros and ban.ros ~= "Onbekend" and ban.ros == ros then matches = matches + 1 end
        if ban.hardware_id and ban.hardware_id ~= "Onbekend" and ban.hardware_id == hardware_id then matches = matches + 1 end
        if ban.token_fingerprint and ban.token_fingerprint ~= "Onbekend" and ban.token_fingerprint == token_fingerprint then matches = matches + 1 end
        if ban.tokens and type(ban.tokens) == "table" and #ban.tokens > 0 then
            for _, t in ipairs(tokens) do
                for _, bt in ipairs(ban.tokens) do
                    if t == bt then matches = matches + 1 break end
                end
            end
        end
        if matches >= 2 then
            return true
        end
    end

    return false
end

