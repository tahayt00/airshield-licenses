-- Track unknown trigger violations per player
local playerUnknownTriggerCounts = {}
local playerUnknownTriggerLastReset = {}

-- Reset counters periodically
CreateThread(function()
    while true do
        Wait(60000) -- Check every minute
        local resetTime = (Config.Client and Config.Client['Anti Unknown Trigger'] and Config.Client['Anti Unknown Trigger']['ResetTime'] or 300) * 1000
        local currentTime = os.time() * 1000
        
        for playerId, _ in pairs(playerUnknownTriggerCounts) do
            if not playerUnknownTriggerLastReset[playerId] or (currentTime - playerUnknownTriggerLastReset[playerId]) > resetTime then
                playerUnknownTriggerCounts[playerId] = {}
                playerUnknownTriggerLastReset[playerId] = currentTime
            end
        end
    end
end)

-- Handler for unknown trigger detection from client
RegisterNetEvent('AirShield:unknownTriggerDetected')
AddEventHandler('AirShield:unknownTriggerDetected', function(eventName, count, isSuspicious)
    local src = source
    
    if not src or src == 0 then return end
    if not Config.Protections['Anti Unknown Trigger'] then return end
    
    local config = Config.Client['Anti Unknown Trigger']
    if not config or not config['Enabled'] then return end
    
    local playerName = GetPlayerName(src) or "Unknown"
    local eventNameStr = tostring(eventName or '')
    
    -- Initialize counters for player
    if not playerUnknownTriggerCounts[src] then
        playerUnknownTriggerCounts[src] = {}
        playerUnknownTriggerLastReset[src] = os.time() * 1000
    end
    
    -- Check if trigger is actually whitelisted (double-check server-side)
    local isWhitelisted = false
    if Config.WhitelistedTriggers then
        for _, whitelisted in ipairs(Config.WhitelistedTriggers) do
            if eventNameStr == whitelisted then
                isWhitelisted = true
                break
            end
        end
    end
    
    -- Skip if whitelisted
    if isWhitelisted then return end
    
    -- Count violations
    playerUnknownTriggerCounts[src][eventNameStr] = (playerUnknownTriggerCounts[src][eventNameStr] or 0) + (count or 1)
    
    local violationCount = playerUnknownTriggerCounts[src][eventNameStr]
    local maxUnknown = config['MaxUnknownTriggers'] or 3
    
    -- Log to Discord if configured
    if Config.TriggerResourceslogs and Config.TriggerResourceslogs ~= "" then
        local reason = string.format("[UNKNOWN_TRIGGER] %s - Count: %d", eventNameStr, violationCount)
        if isSuspicious then
            reason = reason .. " (Suspicious Pattern)"
        end
        
        PerformHttpRequest(Config.TriggerResourceslogs, function(err, text, headers) end, 'POST', json.encode({
            username = "AirShield",
            embeds = {{
                title = "🚨 Unknown Trigger Detected",
                description = string.format("**Player:** %s (ID: %d)\n**Trigger:** `%s`\n**Violation Count:** %d\n**Suspicious:** %s", 
                    playerName, src, eventNameStr, violationCount, isSuspicious and "Yes" or "No"),
                color = isSuspicious and 15158332 or 16776960,
                timestamp = os.date("!%Y-%m-%dT%H:%M:%S")
            }}
        }), { ['Content-Type'] = 'application/json' })
    end
    
    -- Ban if threshold exceeded
    if violationCount >= maxUnknown or (isSuspicious and violationCount >= 1) then
        local banReason = string.format("Unknown Trigger Detected: %s (Count: %d)", eventNameStr, violationCount)
        if isSuspicious then
            banReason = banReason .. " - Suspicious Pattern"
        end
        
        -- Reset counter
        playerUnknownTriggerCounts[src][eventNameStr] = 0
        
        -- Apply enforcement action
        local action = Config.EnforcementActions['Anti Unknown Trigger'] or 'ban'
        if action == 'ban' then
            banPlayertrigger(src, banReason, "UNKTRIG-01")
        elseif action == 'kick' then
            DropPlayer(src, "[AirShield] " .. banReason)
        end
    end
end)

