-- REMOTE BLACKLIST API
local remoteBlacklistUsers = {}
local lastBlacklistUpdate = 0

local function checkRemoteBlacklist(source)
    -- Check for updates on every connection but throttle to once every 30 seconds to avoid spamming GitHub
    if os.time() - lastBlacklistUpdate > 30 then
        local finishedUpdate = false
        PerformHttpRequest("https://raw.githubusercontent.com/Negrotaha/airshield-licenses/main/licenses.json", function(status, response, headers)
            if status == 200 and response then
                local ok, data = pcall(json.decode, response)
                if ok and data and data.blacklisted_users then
                    remoteBlacklistUsers = data.blacklisted_users
                    lastBlacklistUpdate = os.time()
                end
            end
            finishedUpdate = true
        end, "GET", "")
        
        local updateTimer = 0
        while not finishedUpdate and updateTimer < 30 do -- Wait up to 3 seconds for the update to complete
            Wait(100)
            updateTimer = updateTimer + 1
        end
    end

    if not remoteBlacklistUsers or #remoteBlacklistUsers == 0 then return false end
    
    local identifiers = GetPlayerIdentifiers(source)
    local playerDiscord = nil
    local playerLicense = nil
    
    for _, id in ipairs(identifiers) do
        if string.sub(id, 1, 8) == "discord:" then
            playerDiscord = string.sub(id, 9)
        elseif string.sub(id, 1, 8) == "license:" then
            playerLicense = string.sub(id, 9)
        end
    end
    
    for _, user in ipairs(remoteBlacklistUsers) do
        -- Check Discord
        if user.discord_id and playerDiscord == tostring(user.discord_id) then
            return true
        end
        -- Check License
        if user.license and playerLicense then
            local cleanLicense = tostring(user.license):gsub("license:", "")
            if playerLicense == cleanLicense then
                return true
            end
        end
    end
    
    return false
end

-- SECURITY & EVENT OBFUSCATION HANDLER
local SecurityConfig = {
    Salt = "AS_SECURE_SALT_99281_CHANGE_ME",
    ObfuscateEvents = true
}

local function GetEncryptedEventName(eventName)
    if not SecurityConfig.ObfuscateEvents then return eventName end
    local hash = GetHashKey(eventName .. SecurityConfig.Salt)
    return "AS_EVT_" .. tostring(hash)
end

-- Handle Resource Stop Attempt (from injected air.lua)
local resourceStoppedEvent = GetEncryptedEventName("AirShield:Security:ResourceStopped")
RegisterNetEvent(resourceStoppedEvent, function(stoppedResource)
    local src = source
    if not src then return end
    
    print("^1[AirShield] SECURITY ALERT: Client " .. GetPlayerName(src) .. " attempted to stop resource: " .. stoppedResource .. "^7")
    DropPlayer(src, "AirShield Protection: Illegal Resource Stop Detected.")
end)

