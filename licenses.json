function LoadBans()
    local bans = {}
    local content = LoadResourceFile(GetCurrentResourceName(), "html/ban.json")
    if content and content ~= "" then
        local ok, data = pcall(json.decode, content)
        if ok and type(data) == "table" then
            bans = data
        end
    end
    return bans
end

function SaveBans(bans)
    local payload = json.encode(bans, { indent = true })
    SaveResourceFile(GetCurrentResourceName(), "html/ban.json", payload, -1)
end

