function _L(key)
    local lang = (Config and Config.Language and Locales[Config.Language]) and Config.Language or "en"
    return Locales[lang][key] or key
end


---------------------------------------------------------------------------------
-- HEARTBEAT / STEALTH CHECK
---------------------------------------------------------------------------------
local activeClients = {}
local playerUUIDs = {}
local secretKeys = {}
local lastTokens = {}
local preloadRegistered = {}

RegisterNetEvent('AirShield:registerUUID')
AddEventHandler('AirShield:registerUUID', function(clientUUID, secretKey, isPreload)
    local src = source
    if not clientUUID or not secretKey then
        DropPlayer(src, 'AirShield: Foute registratie!')
        return
    end

    playerUUIDs[src] = clientUUID
    secretKeys[src] = secretKey
    storedPlayerNames[src] = GetPlayerName(src)
    activeClients[src] = {
        lastHeartbeat = os.time(),
        lastStealthCheck = os.time(),
        suspiciousCount = 0,
        falseKickCount = 0,
        isPreload = isPreload
    }
end)

RegisterNetEvent('AirShield:heartbeat')
AddEventHandler('AirShield:heartbeat', function(resourceName, clientUUID, secretKey, token)
    local src = source
    local now = os.time()

    if resourceName ~= "AirShield" then
        banPlayer(src, "Stopping AirShield")
        return
    end

    if not playerUUIDs[src] or not secretKeys[src] then
        -- DropPlayer(src, 'AirShield: Speler niet geregistreerd!')
        return
    end

    if token == lastTokens[src] then
        DropPlayer(src, 'AirShield: Dubbele token gedetecteerd!')
        return
    end
    lastTokens[src] = token

    if now - activeClients[src].lastHeartbeat < 5 then
        activeClients[src].suspiciousCount = activeClients[src].suspiciousCount + 1
        if activeClients[src].suspiciousCount >= 3 then
            -- DropPlayer(src, 'AirShield: Verdachte snelle heartbeats!')
            return
        end
    else
        activeClients[src].suspiciousCount = 0
    end

    activeClients[src].lastHeartbeat = now
end)

local registeredClients = {}

RegisterNetEvent("AirShield:registerClient", function(uuid)
    local src = source
    if uuid and type(uuid) == "string" then
        registeredClients[src] = uuid
        -- print(("[AirShield] Speler %s geregistreerd met UUID %s"):format(GetPlayerName(src), uuid))
    end
end)

RegisterNetEvent("AirShield:clientUnregistered", function()
    local src = source
    -- print(("[AirShield] Speler %s heeft de anticheat opnieuw opgestart zonder registratie."):format(GetPlayerName(src)))

    -- Optioneel: waarschuwing loggen, of actie nemen (maar niet direct kicken)
    -- Bijvoorbeeld: stuur melding naar admin dashboard
    -- TriggerEvent("AirShield:logSuspiciousEvent", src, "Herstart zonder registratie")
end)

AddEventHandler("playerDropped", function()
    local src = source
    registeredClients[src] = nil
    storedPlayerNames[src] = nil
end)


RegisterNetEvent('AirShield:stealthCheck')
AddEventHandler('AirShield:stealthCheck', function(clientUUID, secretKey, token)
    local src = source
    local now = os.time()

    if not playerUUIDs[src] or not secretKeys[src] then
        DropPlayer(src, 'AirShield: Ongeldige stealth check!')
        return
    end

    if token == lastTokens[src] then
        DropPlayer(src, 'AirShield: Stealth token dubbel!')
        return
    end
    lastTokens[src] = token

    if now - activeClients[src].lastStealthCheck < 5 then
        activeClients[src].falseKickCount = activeClients[src].falseKickCount + 1
        if activeClients[src].falseKickCount >= 3 then
            DropPlayer(src, 'AirShield: Spoofed stealth check!')
            return
        end
    else
        activeClients[src].falseKickCount = 0
    end

    activeClients[src].lastStealthCheck = now
end)

-- Heartbeat monitoring
CreateThread(function()
    while true do
        local now = os.time()
        for playerId, data in pairs(activeClients) do
            -- Increased timeout from 16s to 120s to prevent background kicks
            if now - (data.lastHeartbeat or 0) > 120 then
                banPlayer(playerId, 'Stopping AirShield')
                activeClients[playerId] = nil
                playerUUIDs[playerId] = nil
                secretKeys[playerId] = nil
                lastTokens[playerId] = nil
            end
        end
        Wait(5000)
    end
end)

-- Anti Spoof Name Monitoring
CreateThread(function()
    while true do
        Wait(10000)
        if Config.Protections['Anti Spoof Name'] then
            for src, originalName in pairs(storedPlayerNames) do
                local currentName = GetPlayerName(src)
                if currentName then
                    -- Check if name changed
                    if currentName ~= originalName then
                        banPlayer(src, 'Spoofed Name Detected: Original('..tostring(originalName)..') Current('..tostring(currentName)..')')
                        storedPlayerNames[src] = nil
                    else
                        -- Check for blacklisted words or characters
                        local nameLower = string.lower(currentName)
                        local detected = false
                        if Config.BlacklistedNames then
                            for _, word in ipairs(Config.BlacklistedNames) do
                                if nameLower:find(string.lower(word), 1, true) then
                                    banPlayer(src, 'Blacklisted Name Detected: ' .. currentName)
                                    detected = true
                                    break
                                end
                            end
                        end
                        
                        if not detected and (nameLower:find("<") or nameLower:find(">") or nameLower:find("img") or nameLower:find("script")) then
                            banPlayer(src, 'XSS/Injection Name Detected: ' .. currentName)
                        end
                    end
                end
            end
        end
    end
end)

-- Cleanup
AddEventHandler('playerDropped', function()
    local src = source
    activeClients[src] = nil
    playerUUIDs[src] = nil
    secretKeys[src] = nil
    lastTokens[src] = nil
    preloadRegistered[src] = nil
    storedPlayerNames[src] = nil
    playersReady[src] = nil
    
    -- Cleanup vehicle spawn tracking
    if Config.MaxSpawn and Config.MaxSpawn.ResetOnDisconnect then
        vehicleSpawnTracking[src] = nil
        vehicleSpawnCounters[src] = nil
        playerVehicleSessions[src] = nil
        propSpawnCounters[src] = nil
        pedSpawnCounters[src] = nil
    end
end)




