CreateThread(function()
    while true do
        Wait((Config.GiveMoneyCheckInterval or 10000))
        if not Config.Protections['Anti Give Money'] then goto cont end
        for _, src in ipairs(GetPlayers()) do
            if not isExempt(src) and not IsPlayerAdmin(src) then
                local total = 0
                if UseQBCore and QBCore then
                    local qb = QBCore.Functions.GetPlayer(src)
                    if qb and qb.PlayerData and qb.PlayerData.money then
                        local m = qb.PlayerData.money
                        total = (m.cash or 0) + (m.bank or 0)
                    end
                elseif UseESX and ESX then
                    local ex = ESX.GetPlayerFromId(src)
                    if ex then
                        local cash = ex.getMoney and ex.getMoney() or 0
                        local bankAcc = ex.getAccount and ex.getAccount('bank') or nil
                        local bank = bankAcc and bankAcc.money or 0
                        total = (cash or 0) + (bank or 0)
                    end
                end
                _G.__moneyPrev = _G.__moneyPrev or {}
                local prev = _G.__moneyPrev[src]
                if prev then
                    local diff = total - prev
                    local threshold = Config.GiveMoneyMaxIncrease or 50000
                    if diff and diff > threshold then
                        banPlayertrigger(src, 'Suspicious Money Increase Detected', 'MONEY', true)
                    end
                end
                _G.__moneyPrev[src] = total
            end
        end
        ::cont::
    end
end)
