RegisterNetEvent('AirShield:banHandler')
AddEventHandler('AirShield:banHandler', function(reason)
    local src = source
    -- print('[DEBUG] AirShield:banHandler triggered by source: ' .. tostring(src) .. ', reason: ' .. tostring(reason))

    if not src or src == 0 then
        -- print('[DEBUG] Invalid source (nil or 0), skipping ban')
        return
    end

    if reason == 'Teleport Detected' then
        if WhiteListedTeleports[src] then
            -- print('[DEBUG] Player is whitelisted for teleport, skipping ban')
            return
        else
            -- print('[DEBUG] Teleport not whitelisted, banning player')
            banPlayer(src, reason)
            return
        end
    end

    -- print('Banning player for reason:', reason)
    banPlayer(src, reason)
end)

RegisterNetEvent('AirShield:banAttacker')
AddEventHandler('AirShield:banAttacker', function(targetId, reason)
    local src = source
    
    if not src or src == 0 then return end
    if not targetId then return end
    
    -- Basic validation: Ensure targetId is valid and not the caller (unless testing)
    if targetId == src then
        -- This shouldn't happen in normal flow, but just in case
        return 
    end
    
    -- Optional: Add more validation here (e.g. check if src is trusted, or rate limit)
    
    -- Log this action
    print('[AirShield] Player ' .. GetPlayerName(src) .. ' (' .. src .. ') reported attacker ' .. targetId .. ' for: ' .. reason)
    
    banPlayer(targetId, reason .. " (Reported by Victim ID: " .. src .. ")")
end)


