-- Advanced Vehicle Spawn Protection
-- Note: Variables are initialized at the top of the file to prevent nil errors

-- Helper Functions
local function isAllowedResource(resource)
    if not resource or resource == "" then return false end
    for _, allowed in ipairs(Config.AllowedVehicleSpawnResources or {}) do
        if resource == allowed then
            return true
        end
    end
    return false
end

-- Resource Whitelist Check Function
-- If a resource is in the whitelist, it bypasses ALL anti-cheat protections
local function isResourceWhitelisted(resource)
    if not resource or resource == "" or resource == "unknown" then
        return false
    end
    
    -- Get whitelisted resources from config
    local whitelistedResources = Config.WhitelistedResources or {}
    
    -- Check if resource is in whitelist
    for _, whitelistedResource in ipairs(whitelistedResources) do
        if resource == whitelistedResource then
            return true
        end
    end
    
    return false
end

-- Full Whitelist Resources Check Function
-- If a resource is in the full whitelist, it bypasses ALL anti-cheat protections like admin
-- This is similar to admin bypass but for specific resources
local function isResourceFullWhitelisted(resource)
    if not resource or resource == "" or resource == "unknown" then
        return false
    end
    
    -- Get full whitelisted resources from config
    local fullWhitelistResources = Config.FullWhitelistResources or {}
    
    -- Check if resource is in full whitelist
    for _, fullWhitelistedResource in ipairs(fullWhitelistResources) do
        if resource == fullWhitelistedResource then
            return true
        end
    end
    
    return false
end

-- Check if player's invoking resource is full whitelisted
local function isPlayerResourceFullWhitelisted(playerId)
    if not playerId or playerId <= 0 then return false end
    
    -- Try to get the invoking resource from the player's context
    -- This is a best-effort check since we can't always get the exact resource
    -- In most cases, we check the resource when events are triggered
    return false
end

local function isNPCVehicle(entity)
    -- Check if vehicle is NPC vehicle (should be ignored)
    local isNetworked = NetworkGetEntityIsNetworked(entity)
    if not isNetworked then
        return true -- Not networked = NPC vehicle
    end
    
    local owner = NetworkGetEntityOwner(entity)
    if owner == -1 then
        return true -- No owner = NPC vehicle
    end
    
    -- Check if driver is NPC
    local driver = GetPedInVehicleSeat(entity, -1)
    if driver ~= 0 and not IsPedAPlayer(driver) then
        return true -- NPC driver = NPC vehicle
    end
    
    -- Check population type (natural spawns)
    local popType = GetEntityPopulationType(entity)
    if popType == 4 or popType == 5 or popType == 6 or popType == 7 then
        return true -- Natural population = NPC vehicle
    end
    
    return false
end

