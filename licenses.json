            -- Use the search API format which works better for displaying locations
            gmap = "[google map](https://www.google.com/maps/search/?api=1&query=" .. tostring(lat) .. "," .. tostring(lon) .. ")"
        elseif CITY and CITY ~= "Not Taken" and CITY ~= "" then
            -- Fallback to city name if coordinates not available
            gmap = "[google map](https://www.google.com/maps/search/?api=1&query=" .. CITY .. ")"
        end
        
        -- Format city display with country flag
        local cityDisplay = "Not Taken"
        if CITY and CITY ~= "Not Taken" and CITY ~= "" then
            local flag = "🌍"
            if cc and #cc == 2 then
                local ok, v = pcall(function()
                    local base = 0x1F1E6
                    local a = string.byte(string.upper(cc), 1) - string.byte("A") + base
                    local b = string.byte(string.upper(cc), 2) - string.byte("A") + base
                    return utf8.char(a, b)
                end)
                if ok and v then flag = v end
            end
            cityDisplay = flag .. " " .. CITY
        end
        
        -- Format IP display
