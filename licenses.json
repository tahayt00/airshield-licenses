        if qbPlayer and qbPlayer.PlayerData then
            local pd = qbPlayer.PlayerData
            local group = pd.group or pd.permission or (pd.job and pd.job.name) or "user"
            return Config.ADMIN_GROUPS and Config.ADMIN_GROUPS[group] == true
        end
        return false
    elseif UseESX and ESX then
        local xPlayer = ESX.GetPlayerFromId(source)
        if xPlayer then
            local group = xPlayer.getGroup()
            return Config.ADMIN_GROUPS and Config.ADMIN_GROUPS[group] == true
        end
        return false
    end

    return false
end

function GetPlayerCharacterName(source)
    if UseESX and ESX then
        local xPlayer = ESX.GetPlayerFromId(source)
        return (xPlayer and xPlayer.getName()) or "Unknown"
    elseif UseQBCore and QBCore then
        local Player = QBCore.Functions.GetPlayer(source)
        if Player and Player.PlayerData and Player.PlayerData.charinfo then
            local fn = Player.PlayerData.charinfo.firstname or ""
            local ln = Player.PlayerData.charinfo.lastname or ""
            return (fn .. " " .. ln):match("%S") and (fn .. " " .. ln) or "Unknown"
        end
        return "Unknown"
    end

    return "Unknown"
end

