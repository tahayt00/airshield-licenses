AddEventHandler("AirShield:ScreenshotTaken2", function(screenshotUrl, reason, banId)
    local src = source
    local name = GetPlayerName(src)
    if not name then return end

    -- Identifiers
    local license, steamID, discord, playerip = "N/A", "N/A", "N/A", "N/A"
    for _, v in ipairs(GetPlayerIdentifiers(src)) do
        if v:find("license:") then license = v end
        if v:find("steam:") then steamID = v end
        if v:find("discord:") then
            local id = v:gsub("discord:", "")
            discord = "<@" .. id .. "> | discord:" .. id
        end
        if v:find("ip:") then playerip = v:gsub("ip:", "") end
    end

    -- IP API Lookup
    PerformHttpRequest("http://ip-api.com/json/"..GetPlayerEndpoint(src).."?fields=66846719", function(err, data)
        local ISP, CITY, COUNTRY, PROXY = "N/A", "N/A", "N/A", "OFF"
        if data then
            local d = json.decode(data)
            ISP = d.isp or ISP
            CITY = d.city or CITY
            COUNTRY = d.country or COUNTRY
            PROXY = (d.proxy == true and "ON" or "OFF")
        end

        -- Webhook embed
        local embed = {{
            color = 16753920,
            title = name .. " pressed a suspicious key",
            author = {
                name = "AirShield",
                icon_url = "https://zupimages.net/up/25/50/uv0h.png"
            },
            fields = {
                { name = "`Reason`", value = reason, inline = false },
                { name = "`Name`", value = name, inline = true },
                { name = "`Steam`", value = steamID, inline = true },
                { name = "`License`", value = license, inline = false },
                { name = "`Discord`", value = discord, inline = false },
                {
                    name = "`IP Info`",
                    value = ("IP: ||%s||\nISP: ||%s||\nCountry: ||%s||\nCity: ||%s||\nProxy: ||%s||"):format(
                        playerip, ISP, COUNTRY, CITY, PROXY
                    ),
                    inline = false
                }
            },
            image = {
                url = screenshotUrl or "https://i.postimg.cc/s2vLBrxy/Air-Secure-6.png"
            },
            footer = {
                text = "AirShield • " .. os.date("%d-%m-%Y %H:%M:%S"),
                icon_url = "https://i.postimg.cc/tCsDt5yt/Ontwerp-zonder-titel-6-removeb-1.png"
            }
        }}

        -- Update ban data with screenshot URL
        local bansFile = LoadResourceFile(GetCurrentResourceName(), "html/ban.json")
        local bans = {}
        
        if bansFile then
            bans = json.decode(bansFile) or {}
        else
            print("Warning: bans.json not found for screenshot update.")
        end
        
        -- Find the ban by banId and update the screenshot_url
        local banUpdated = false
        for i, ban in ipairs(bans) do
            if ban.id == banId then
                ban.screenshot_url = screenshotUrl
                banUpdated = true
                break
            end
        end
        
        if banUpdated then
            SaveResourceFile(GetCurrentResourceName(), "html/ban.json", json.encode(bans, { indent = true }), -1)
        end
        
        PerformHttpRequest(Config.detectionlogs, function(e, t, h)
            if e ~= 204 and e ~= 200 then
                print("^1[AirShield] Webhook failed: " .. tostring(e))
            end
        end, "POST", json.encode({ 
            username = "AirShield",
            avatar_url = "https://zupimages.net/up/25/50/pb1f.png",
            embeds = embed 
        }), {
            ["Content-Type"] = "application/json"
        })
    end)
end)



