        if ban.tokens and type(ban.tokens) == "table" and #ban.tokens > 0 then
            for _, t in ipairs(tokens) do
                for _, bt in ipairs(ban.tokens) do
                    if t == bt then matches = matches + 1 break end
                end
            end
        end
        if matches >= 2 then 
            isBanned = true
            banReason = ban.reason or ban.details or ban.REASON or "Onbekende reden"
            banId = ban.id or ban.BANID or ban.ban_id or "0000"
            break
        end
    end

    local serverName = Config.Servername or 'Server Naam'

