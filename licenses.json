AddEventHandler("AirShield:ScreenshotTaken", function(screenshotUrl, reason, newBanId)
    local playerName = GetPlayerName(source)
    if not playerName then 
        print('^2[AirShield]^1 | INVALID PLAYER ID')
        return 
    end

    -- Spieler-Informationen sammeln
    local license, steamID, liveid, xblid, discord, playerip = "Null","Null","Null","Null","Null","Null"
    for k,v in ipairs(GetPlayerIdentifiers(source)) do
        if string.sub(v, 1, string.len("license:")) == "license:" then
            license = v
        elseif string.sub(v, 1, string.len("steam:")) == "steam:" then
            steamID = v
        elseif string.sub(v, 1, string.len("live:")) == "live:" then
            liveid = v
        elseif string.sub(v, 1, string.len("xbl:")) == "xbl:" then
            xblid = v
        elseif string.sub(v, 1, string.len("discord:")) == "discord:" then
            discordid = string.sub(v, 9)
            discord = "<@" .. discordid .. "> | discord:" .. discordid
        elseif string.sub(v, 1, string.len("ip:")) == "ip:" then
            playerip = v
        end
    end

    -- If newBanId is not provided, try to retrieve it from ban.json
    if not newBanId or newBanId == "Unknown" then
        local bansFile = LoadResourceFile(GetCurrentResourceName(), "html/ban.json")
        if bansFile then
            local bans = json.decode(bansFile) or {}
            -- Find the most recent ban for this player by license
            for i = #bans, 1, -1 do
                local ban = bans[i]
                if ban and (ban.license == license or ban.name == playerName) then
                    newBanId = ban.id
                    break
                end
            end
        end
    end

    -- Extract IP address from playerip identifier
    local ipAddress = "Unknown"
    if playerip and playerip ~= "Null" and playerip ~= "Onbekend" then
        -- Remove "ip:" prefix if present
        if string.sub(playerip, 1, 3) == "ip:" then
            ipAddress = string.sub(playerip, 4)
        else
            ipAddress = tostring(playerip)
        end
    else
        -- Fallback to GetPlayerEndpoint if identifier not found
        local endpoint = GetPlayerEndpoint(source)
        if endpoint then
            ipAddress = endpoint:match("(%d+%.%d+%.%d+%.%d+)") or endpoint
        end
    end

    -- IP-Informationen abrufen
    PerformHttpRequest("http://ip-api.com/json/"..ipAddress.."?fields=66846719", function(ERROR, DATA, RESULT)
        local ISP, CITY, COUNTRY, PROXY = "Not Taken", "Not Taken", "Not Taken", "OFF"
        local lat, lon, cc = nil, nil, nil
        
        if DATA ~= nil then
            local TABLE = json.decode(DATA)
            if TABLE ~= nil then
                ISP = TABLE["isp"] or "Not Taken"
                CITY = TABLE["city"] or "Not Taken"
                COUNTRY = TABLE["country"] or "Not Taken"
                lat = TABLE["lat"] or nil
                lon = TABLE["lon"] or nil
                cc = TABLE["countryCode"] or nil
                if TABLE["proxy"] == true then
                    PROXY = "ON"
                else
                    PROXY = "OFF"
                end
            end
        end

        -- Ensure Ban ID is always a valid string
        local banIdDisplay = "Unknown"
        if newBanId and newBanId ~= "" and newBanId ~= "Unknown" then
            banIdDisplay = tostring(newBanId)
        end

        -- Format platform IDs
        local steamDisplay = (steamID and steamID ~= "Null" and steamID ~= "Onbekend") and steamID or "no linked"
        local xboxDisplay = (xblid and xblid ~= "Null" and xblid ~= "Onbekend" and xblid ~= "no linked") and xblid or "no linked"
        local liveDisplay = (liveid and liveid ~= "Null" and liveid ~= "Onbekend" and liveid ~= "no linked") and liveid or "no linked"

        -- Get IP information and format city with flag emoji
        -- Create Google Maps link with proper format to show player location
