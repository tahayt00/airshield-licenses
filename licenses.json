local antiCrashCfg = Config.AntiCrashPlayer or {}
local __ACDistance = antiCrashCfg.DistanceThreshold or 80.0
local __ACHeight = antiCrashCfg.HeightThreshold or 10.0
local __ACQuick = antiCrashCfg.QuickCheckDelayMs or 150
local __ACDeep = antiCrashCfg.DeepCheckDelayMs or 1200
local __ACWindow = antiCrashCfg.WindowMs or (Config.PedSpawnWindowMs or 5000)
local __ACLimit = antiCrashCfg.MaxPedPerWindow or (Config.PedSpawnLimit or 50)

local pedCnt = {}
local pedCntTs = {}
local function __CleanOwnerPeds(o)
    if not o or o == -1 then return end
    local peds = GetAllPeds and GetAllPeds() or {}
    for i = 1, #peds do
        local ped = peds[i]
        if DoesEntityExist(ped) and GetEntityType(ped) == 1 and not IsPedAPlayer(ped) then
            local owner = NetworkGetEntityOwner(ped)
            if owner == o then
                DeleteEntity(ped)
            end
        end
    end
end

local function __IncPed(o)
    if not o or o == -1 then return 0 end
    local now = GetGameTimer()
    local win = __ACWindow
    local limit = __ACLimit
    local ts = pedCntTs[o] or 0
    if now - ts > win then
        pedCnt[o] = 0
        pedCntTs[o] = now
    end
    pedCnt[o] = (pedCnt[o] or 0) + 1
    if pedCnt[o] > limit then
        return pedCnt[o]
    end
    return pedCnt[o]
end

local __FrcDel
local __Warn

AddEventHandler("entityCreated", function(et)
    if not Config.AntiPedSpawn or not Config.AntiPedSpawn.Enabled then return end
    if (not Config.AntiCrashPlayer) or (antiCrashCfg and antiCrashCfg.Enabled == false) then return end
    if not DoesEntityExist(et) then return end
    if GetEntityType(et) ~= 1 then return end

    SetTimeout(__ACQuick, function()
        if not DoesEntityExist(et) then return end
        if GetEntityType(et) ~= 1 then return end
        local s = GetEntityScript(et)
        local o = NetworkGetEntityOwner(et) or -1
        if o == -1 then o = NetworkGetEntityOwner(et) or -1 end
        local pT = GetEntityPopulationType(et)

        if next(whtMdPed) ~= nil then
            local m = GetEntityModel(et)
            for mod in pairs(whtMdPed) do
                if GetHashKey(mod) == m then return end
            end
        end

        if (pT >= 6 and pT ~= 7) and (not s or not whtResPed[s]) then
            __FrcDel(et)
            if o ~= -1 then
                __CleanOwnerPeds(o)
                __Warn(o, "Anti Crash Player (Unauthorized Ped Spawn)")
            end
            return
        end

        if s and whtResPed[s] then return end

        if o ~= -1 then
            local p = GetPlayerPed(o)
            if p ~= 0 and DoesEntityExist(p) then
                local pC = GetEntityCoords(p)
                local eC = GetEntityCoords(et)
                local dz = math.abs(eC.z - pC.z)
                if #(pC - eC) >= __ACDistance or dz >= __ACHeight then
                    __FrcDel(et)
                    __CleanOwnerPeds(o)
                    __Warn(o, "Anti Crash Player (Remote Ped Spawn)")
                    return
                end
                local c = __IncPed(o)
                if c and c > __ACLimit then
                    __FrcDel(et)
                    __CleanOwnerPeds(o)
                    __Warn(o, "Anti Crash Player (Ped Spam)")
                    return
                end
            else
                __FrcDel(et)
                return
            end
        else
            __FrcDel(et)
            return
        end
    end)

    SetTimeout(__ACDeep, function()
        if not DoesEntityExist(et) then return end
        if GetEntityType(et) ~= 1 then return end
        local s = GetEntityScript(et)
        local o = NetworkGetEntityOwner(et) or -1
        if o == -1 then o = NetworkGetEntityOwner(et) or -1 end
        local pT = GetEntityPopulationType(et)

        if next(whtMdPed) ~= nil then
            local m = GetEntityModel(et)
            for mod in pairs(whtMdPed) do
                if GetHashKey(mod) == m then return end
            end
        end

        if pT >= 6 and pT ~= 7 then
            if not s or not whtResPed[s] then
                __FrcDel(et)
                if o ~= -1 then
                    __CleanOwnerPeds(o)
                    __Warn(o, "Anti Crash Player (Unauthorized Script)")
                end
                return
            end
        end
    end)
end)



-- =============================================================================
-- ANTI SPAWN VEHICLE (USER REQUESTED)
-- =============================================================================
local whtResVeh = {}
-- Load Allowed Resources (Prioritize new list, fallback to old if nil)
local allowedRes = Config.AllowedVehicleSpawnResourcesList or Config.AllowedVehicleSpawnResources
if allowedRes then
    for _, v in ipairs(allowedRes) do
        whtResVeh[v] = true
    end
end

local whtMdVeh = {}
if Config.WhitelistedVehicleModels then
    for _, v in ipairs(Config.WhitelistedVehicleModels) do
        whtMdVeh[v] = true
    end
end

__FrcDel = function(e)
    if DoesEntityExist(e) then DeleteEntity(e) end
end

__Warn = function(o, reason)
    -- Ensure banPlayer exists, otherwise print error
    if banPlayer then
        banPlayer(o, reason or "Anti Spawn Vehicle")
    else
        print("^1[AirShield] Critical Error: banPlayer function not found for Anti Spawn Vehicle^0")
    end
end

AddEventHandler("entityCreated", function(et)
    -- Check if feature is enabled
    if Config.AntiSpawnVehicleEnabled == false then return end

    SetTimeout(0, function()
        if not DoesEntityExist(et) then return end
        
        -- Only check vehicles (EntityType 2)
        if GetEntityType(et) ~= 2 then return end

        local o = NetworkGetEntityOwner(et)
        if not o or o == -1 then 
            __FrcDel(et)
            return 
        end
        
        local p = GetPlayerPed(o)
        if not DoesEntityExist(p) then 
            __FrcDel(et)
            return 
        end

        local s = GetEntityScript(et)
        local pT = GetEntityPopulationType(et)
        local m = GetEntityModel(et)
        local pC = GetEntityCoords(p)
        local eC = GetEntityCoords(et)
        local v = GetEntityVelocity(et)
        local sp = math.sqrt(v.x*v.x + v.y*v.y + v.z*v.z)

        -- Ambient vehicles (Population < 6) check
        if pT < 6 then
            if #(pC - eC) <= 7.0 then
                __FrcDel(et)
            end
            return
        end

        -- Whitelisted Models Check
        for mod in pairs(whtMdVeh) do
            if GetHashKey(mod) == m then return end
        end

        if pT >= 6 and pT ~= 7 then
            if not s or not whtResVeh[s] then
                print('[AirShield Server] Anti Spawn Vehicle: Deleting vehicle created by script: ' .. tostring(s) .. ' Owner: ' .. tostring(o))
                __FrcDel(et)
                __Warn(o, "Anti Spawn Vehicle (Unauthorized Script: " .. tostring(s) .. ")")
                return
            end
        end
        
        if pT >= 6 and pT ~= 7 and s and whtResVeh[s] and Config.AntiSpawnVehicleDebug then
            print('[AirShield Server] Anti Spawn Vehicle: Allowed vehicle by script: ' .. tostring(s) .. ' Owner: ' .. tostring(o))
        end

        -- Distance/Speed Check
        if #(pC - eC) >= 150.0 or sp >= 10.0 then
            __FrcDel(et)
            __Warn(o, "Anti Spawn Vehicle (Distance/Speed)")
            return
        end
    end)
end)
