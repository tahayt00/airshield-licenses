        end)() then matches = matches + 1 end
        if ban.twitch and ban.twitch == (function()
            for _, id in ipairs(identifiers) do if id:find("twitch:") then return id end end
            return "Onbekend"
        end)() then matches = matches + 1 end
        if ban.vbl and ban.vbl == (function()
            for _, id in ipairs(identifiers) do if id:find("vbl:") then return id end end
