-- Automatic Resource Whitelist
if Config.ResourceWhitelistEnabled then
    local function LoadResourceWhitelist()
        local file = LoadResourceFile(GetCurrentResourceName(), "html/whitelist.json")
        if not file or file == "" then return {} end
        local ok, data = pcall(json.decode, file)
        if ok and type(data) == "table" then return data end
        return {}
    end

    local function SaveResourceWhitelist(list)
        local payload = json.encode(list, { indent = true })
        SaveResourceFile(GetCurrentResourceName(), "html/whitelist.json", payload, -1)
    end

    local function GenerateResourceWhitelist()
        local total = GetNumResources()
        local names = {}
        for i = 0, total - 1 do
            local name = GetResourceByFindIndex(i)
            if name and name ~= GetCurrentResourceName() then
                names[#names+1] = name
            end
        end
        SaveResourceWhitelist({ resources = names })
        print(("[AirShield] Resource whitelist generated with %d entries"):format(#names))
    end

    CreateThread(function()
        local wl = LoadResourceWhitelist()
        if not wl.resources or type(wl.resources) ~= "table" then
            GenerateResourceWhitelist()
        end
    end)

    AddEventHandler('onResourceStart', function(res)
        if res == GetCurrentResourceName() then return end
        local wl = LoadResourceWhitelist()
        local resources = wl.resources or {}
        local known = false
        for _, n in ipairs(resources) do if n == res then known = true break end end
        if not known then
            local action = (Config.ResourceWhitelistAction or 'flag')
            local msg = ("Unknown resource started: %s"):format(res)
            AppendLog('SERVER', 'Unknown Resource', -1, msg, 'AirShield')
            if action == 'block' then
                StopResource(res)
                print("[AirShield] Stopped unknown resource: " .. res)
            end
        end
    end)

    RegisterCommand('regenwhitelist', function(src)
        if src ~= 0 and not IsPlayerAdmin(src) then return end
        GenerateResourceWhitelist()
        if src ~= 0 then
            TriggerClientEvent('chat:addMessage', src, { args = { '^2AirShield', 'Resource whitelist regenerated' } })
        end
    end, true)
end

