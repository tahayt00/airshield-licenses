-- [Entity Spam Logic Ported]
local entitySpamTrackers = {}
AddEventHandler("entityCreating", function(entity)
    local owner = NetworkGetFirstEntityOwner(entity)
    if not owner then return end
    
    if not entitySpamTrackers[owner] then
        entitySpamTrackers[owner] = { count = 0, time = os.time(), coords = {} }
    end
    
    local tracker = entitySpamTrackers[owner]
    if os.time() - tracker.time >= 10 then
        tracker.count = 0
        tracker.time = os.time()
        tracker.coords = {}
    end
    
    tracker.count = tracker.count + 1
    table.insert(tracker.coords, GetEntityCoords(entity))
    
    -- Check for mass spam
    if tracker.count > 20 then -- 20 entities in 10 seconds
        CancelEvent()
        TriggerEvent("AirShield:banHandler", owner, "Entity Spam: " .. tracker.count .. " entities rapidly spawned")
    end
    
    -- Check for same-location spam (AI Peds)
    local sameLocCount = 0
    local entCoords = GetEntityCoords(entity)
    for _, coord in pairs(tracker.coords) do
        if #(entCoords - coord) < 1.0 then
            sameLocCount = sameLocCount + 1
        end
    end
    
    if sameLocCount > 5 then
        CancelEvent()
        TriggerEvent("AirShield:banHandler", owner, "Entity Spam: Stacked Entities")
    end
end)


