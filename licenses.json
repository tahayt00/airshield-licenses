CreateThread(function()
    while not callbacksRegistered do
        Wait(500)
    end

    while true do
        Wait(2000)

        if not Config.Protections or not Config.Protections['Anti Spawn Weapon'] then
            return
        end

        for _, scr in ipairs(GetPlayers()) do
            local player = GetFrameworkPlayer(scr)
            if player then
                local ped = GetPlayerPed(scr)
                if ped and ped ~= 0 then
                    local isDead = GetEntityHealth(ped) <= 0
                    if not isDead then
                        local currentWeapon = GetSelectedPedWeapon(ped)
                        if currentWeapon ~= -1569615261 then
                            local hasWeapon = false
                            local loadout = nil
                            if player.getLoadout then
                                loadout = player.getLoadout()
                            elseif player.PlayerData and player.PlayerData.items then
                                loadout = player.PlayerData.items
                            end
                            if loadout then
                                for _, item in ipairs(loadout) do
                                    local name = item.name or item.weapon or ""
                                    if name ~= "" then
                                        local n = name
                                        if n:find("weapon_") then
                                            n = n:upper()
                                        end
                                        if GetHashKey(n) == currentWeapon then
                                            hasWeapon = true
                                            break
                                        end
                                    end
                                end
                            end
                            weaponMismatchCounts = weaponMismatchCounts or {}
                            local state = weaponMismatchCounts[scr] or {count=0,last=0}
                            if hasWeapon then
                                state.count = 0
                                state.last = GetGameTimer()
                            else
                                local now = GetGameTimer()
                                if now - state.last > 4000 then
                                    state.count = 1
                                else
                                    state.count = state.count + 1
                                end
                                state.last = now
                                if state.count >= 3 then
                                    banPlayer(scr, "Anti Spawn Weapon")
                                    state.count = 0
                                end
                            end
                            weaponMismatchCounts[scr] = state
                        end
                    end
                end
            end
        end
    end
end)



