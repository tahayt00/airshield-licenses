        end)() then matches = matches + 1 end
        if ban.ros and ban.ros == (function()
            for _, id in ipairs(identifiers) do if id:find("ros:") then return id end end
            return "Onbekend"
        end)() then matches = matches + 1 end
        if ban.hardware_id and ban.hardware_id == hwid then matches = matches + 1 end
        local tokenCount = GetNumPlayerTokens(src)
        local tokens = {}
        for i = 0, tokenCount - 1 do tokens[#tokens+1] = GetPlayerToken(src, i) end
        local tokenFingerprint = table.concat(tokens, "|")
