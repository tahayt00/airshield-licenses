    if not dtype or not selected then return end
    
    -- Only flag if weapon type is completely different and suspicious
    -- Allow melee weapons and unarmed to have variations
    local isUnarmed = (selected == 2725352035) -- WEAPON_UNARMED
    local isMelee = (selected >= 2725352035 and selected <= 2728849162) -- Melee weapon range
    
    -- Skip check for melee/unarmed as they can have legitimate variations
    if isUnarmed or isMelee then return end
    
    -- Only ban if weapon type is completely mismatched (obvious spoofing)
    -- Allow some tolerance for network sync issues
    if dtype ~= selected and dtype ~= 0 and selected ~= 0 then
        -- Check if this is a repeated pattern (not just a one-time network issue)
        if not weaponSpoofCounters then weaponSpoofCounters = {} end
        weaponSpoofCounters[source] = (weaponSpoofCounters[source] or 0) + 1
        
        -- Only ban after multiple occurrences to prevent false positives
        -- This prevents false positives from network lag or legitimate game mechanics
        if weaponSpoofCounters[source] >= 10 then
            banPlayer(source, "Spoofed Damage/Weapon Detected")
            CancelEvent()
            weaponSpoofCounters[source] = 0
        end
    else
        -- Reset counter for legitimate damage
        if weaponSpoofCounters then weaponSpoofCounters[source] = 0 end
    end
end)


local WEAPON_UNARMED = 2725352035
local MAX_PUNCH_DISTANCE = 2.0
local MAX_PUNCH_DAMAGE = 3.0
local TIME_WINDOW = 15000
local MIN_PUNCH_DAMAGE = 1.0
local punchData = {}
local punchData2 = {}

AddEventHandler("weaponDamageEvent", function(source, data)
    if not Config.Protections['Anti Kill Punch'] then
        return
    end

    local playerPed = GetPlayerPed(source)
    if not playerPed or source == -1 then return end

    -- Allow damage to all entities, not just players
    -- Only check for punch/kill exploits on player victims
    local victimPed, victimPlayer, isValidVictim = nil, nil, false
    local isPlayerVictim = false
    
    if data.hitGlobalId and data.hitGlobalId ~= 0 then
        local entity = NetworkGetEntityFromNetworkId(data.hitGlobalId)
        if entity and DoesEntityExist(entity) then
            local entityType = GetEntityType(entity)
            if entityType == 1 then -- Ped
                victimPlayer = NetworkGetEntityOwner(entity)
                if victimPlayer and victimPlayer ~= -1 then
                    victimPed = GetPlayerPed(victimPlayer)
                    if victimPed and DoesEntityExist(victimPed) then
                        isValidVictim = true
                        isPlayerVictim = true
                    end
                else
                    -- NPC or non-player ped - allow damage
                    return
                end
            else
                -- Non-ped entity (vehicle, object, etc.) - allow damage
                return
            end
        end
    end
    
    -- Only check for punch exploits on player victims
    if not isPlayerVictim then return end

    punchData[source] = punchData[source] or {count = 0, lastTime = GetGameTimer()}
    punchData2[source] = punchData2[source] or {count = 0, lastTime = GetGameTimer()}
    local currentTime = GetGameTimer()
    local detection = false
    local info = {reasons = {}, cheatType = nil}

    if data.overrideDefaultDamage and data.weaponDamage <= MIN_PUNCH_DAMAGE and data.weaponType == WEAPON_UNARMED then
        punchData2[source].count = punchData2[source].count + 1
        if punchData2[source].count >= 3 then
            detection = true
            table.insert(info.reasons, "Suspicious low punch damage: " .. data.weaponDamage)
        end
    elseif data.weaponDamage >= MAX_PUNCH_DAMAGE then
        punchData2[source].count = 0
    end

    if currentTime - punchData2[source].lastTime > TIME_WINDOW then
        punchData2[source].count = 0
        punchData2[source].lastTime = currentTime
    end

    -- Only check punch exploits, allow legitimate damage
    if victimPed and DoesEntityExist(victimPed) and data.weaponType == WEAPON_UNARMED then
        local attackerPos = GetEntityCoords(playerPed)
        local victimPos = GetEntityCoords(victimPed)
        local distance = #(attackerPos - victimPos)
        -- Increased distance threshold to reduce false positives (allow up to 3.5m for lag compensation)
        if distance > (MAX_PUNCH_DISTANCE + 1.5) then
            -- Only flag if it happens multiple times (network lag can cause occasional issues)
            punchData[source].count = (punchData[source].count or 0) + 1
            if punchData[source].count >= 3 then
                detection = true
                table.insert(info.reasons, "Excessive punch distance: " .. distance)
            end
        else
            punchData[source].count = 0
        end
    end

    -- More lenient impact direction check (allow some variation)
    if data.hasImpactDir and data.weaponType == WEAPON_UNARMED then
        local impactMagnitude = math.sqrt(data.impactDirX^2 + data.impactDirY^2 + data.impactDirZ^2)
        -- Wider tolerance range to account for legitimate variations
        if impactMagnitude > 1.5 or impactMagnitude < 0.5 then
            detection = true
            table.insert(info.reasons, "Invalid punch impact direction: " .. impactMagnitude)
            info.cheatType = "Punch Manipulation"
        end
    end

    -- Only flag missing impact direction if it's clearly an exploit pattern
    if not data.hasImpactDir and data.impactDirX == 0 and data.impactDirY == 0 and data.impactDirZ == 0 and data.weaponType == WEAPON_UNARMED then
        -- Allow this for non-player entities (NPCs, etc.)
        if victimPlayer and victimPlayer ~= -1 then
            -- Only flag if it happens repeatedly
            local missingImpactCount = (punchData[source].missingImpactCount or 0) + 1
            punchData[source].missingImpactCount = missingImpactCount
            if missingImpactCount >= 5 then
                detection = true
                table.insert(info.reasons, "Missing impact direction vector")
                info.cheatType = "Punch Exploit"
            end
        end
    else
        if punchData[source] then punchData[source].missingImpactCount = 0 end
    end

    -- Only flag invalid network ID if it's clearly an exploit
    if data.hitGlobalId == 0 and data.weaponType == WEAPON_UNARMED then
        -- Allow occasional network sync issues
        local invalidIdCount = (punchData[source].invalidIdCount or 0) + 1
        punchData[source].invalidIdCount = invalidIdCount
        if invalidIdCount >= 3 then
            detection = true
            table.insert(info.reasons, "Invalid victim network ID")
            info.cheatType = "Punch Exploit"
        end
    else
        if punchData[source] then punchData[source].invalidIdCount = 0 end
    end

    -- Only ban and cancel if we have strong evidence of cheating
    if detection then
        banPlayer(source, "[Anti-Punch/Kill] Fake Punch detected")
        CancelEvent()
        return
    end

    -- Specific pattern-based detections (Silent Punch, etc.)
    if data.weaponDamage == 296 and data.weaponType == WEAPON_UNARMED then
        banPlayer(source, "[Anti-Punch/Kill] Suspicious melee damage pattern (Code 2)")
        CancelEvent()
    elseif data.weaponType == WEAPON_UNARMED and data.weaponDamage == 200 and data.hitComponent == 0 and data.damageFlags == 525312 then
        banPlayer(source, "[Anti-Punch/Kill] Silent kill attempt (Code 3)")
        CancelEvent()
    elseif data.weaponType == WEAPON_UNARMED and data.damageType == 2 and data.hitComponent == 20 and data.damageFlags == 454 and data.weaponDamage == 0 then
        banPlayer(source, "[Anti-Punch/Kill] Silent kill attempt (Code 4)")
        CancelEvent()
    elseif data.weaponType == WEAPON_UNARMED and data.damageType == 3 and data.hitComponent == 20 and data.damageFlags == 454 and data.weaponDamage == 0 then
        banPlayer(source, "[Anti-Punch/Kill] Silent kill attempt (Code 5)")
        CancelEvent()
    elseif data.weaponType == 133987706 and data.damageTime > 200000 and data.weaponDamage > 200 then
        banPlayer(source, "[Anti-Punch/Kill] Suspicious high-damage hit (Code 6)")
        CancelEvent()
    end
end)

