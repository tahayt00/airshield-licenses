CreateThread(function()
    while not Config or not Config.Protections do Wait(1000) end
    if not Config.Protections['Anti Object Spawn'] then return end
    local maxObjectsLimit = (Config.ObjectProtections and Config.ObjectProtections['MaxObjects']) or 10
    local allowedScripts = {}
    if Config.ObjectProtections and Config.ObjectProtections['AllowedScripts'] then
        for _, script in pairs(Config.ObjectProtections['AllowedScripts']) do
            allowedScripts[script] = true
        end
    end
    while true do
        Wait(2000)
        local objects = GetAllObjects()
        local playerSuspiciousCount = {}
        local objectsToDelete = {}
        for _, obj in ipairs(objects) do
            if DoesEntityExist(obj) then
                local owner = NetworkGetEntityOwner(obj)
                if owner and owner > 0 then
                    if not IsPlayerAdmin(owner) then
                        local script = GetEntityScript(obj)
                        local isAllowed = false
                        if script ~= nil then
                            if allowedScripts[script] then
                                isAllowed = true
                            elseif isResourceWhitelisted(script) or isResourceFullWhitelisted(script) then
                                isAllowed = true
                            end
                        else
                            isAllowed = false
                        end
                        if not isAllowed then
                            -- print('[AirShield Server] Anti Object Spawn: Deleting object created by script: ' .. tostring(script) .. ' Owner: ' .. tostring(owner))
                            playerSuspiciousCount[owner] = (playerSuspiciousCount[owner] or 0) + 1
                            table.insert(objectsToDelete, obj)
                        end
                    end
                end
            end
        end
        for _, obj in ipairs(objectsToDelete) do
            if DoesEntityExist(obj) then
                DeleteEntity(obj)
            end
        end
        for owner, count in pairs(playerSuspiciousCount) do
            if count > maxObjectsLimit then
                banPlayer(owner, 'Anti Object Spawn')
            end
        end
    end
end)
