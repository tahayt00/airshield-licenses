-- XSS Detection Function
local function detectXSS(username)
    if not username or type(username) ~= "string" then
        return false
    end
    
    local nameLower = string.lower(username)
    local nameOriginal = username
    
    -- Check for HTML tags (case-insensitive)
    local htmlTags = {
        "<meta", "<script", "<iframe", "<img", "<svg", "<body", "<style", 
        "<link", "<embed", "<object", "<form", "<input", "<textarea", 
        "<select", "<button", "<frame", "<frameset", "<applet", "<base",
        "<div", "<span", "<p", "<a", "<html", "<head", "<title"
    }
    
    for _, tag in ipairs(htmlTags) do
        if nameLower:find(string.lower(tag), 1, true) then
            return true
        end
    end
    
    -- Check for HTML attributes with event handlers
    local eventHandlers = {
        "onerror", "onload", "onclick", "onmouseover", "onmouseout",
        "onfocus", "onblur", "onchange", "onsubmit", "onreset",
        "onselect", "onunload", "ondblclick", "onkeydown", "onkeyup",
        "onkeypress", "onmousedown", "onmouseup", "onmousemove",
        "http-equiv", "content", "src", "href", "action"
    }
    
    for _, handler in ipairs(eventHandlers) do
        if nameLower:find(string.lower(handler), 1, true) then
            return true
        end
    end
    
    -- Check for JavaScript URLs
    if nameLower:find("javascript:", 1, true) then
        return true
    end
    
    -- Check for HTML entities (encoded XSS attempts)
    local htmlEntities = {
        "&lt;", "&gt;", "&#60;", "&#62;", "&#x3c;", "&#x3e;",
        "&quot;", "&#34;", "&#x22;", "&#39;", "&#x27;",
        "&amp;", "&#38;", "&#x26;"
    }
    
    for _, entity in ipairs(htmlEntities) do
        if nameLower:find(string.lower(entity), 1, true) then
            return true
        end
    end
    
    -- Check for specific XSS patterns
    local xssPatterns = {
        "http-equiv.*refresh",  -- Meta refresh redirects
        "http-equiv.*content",  -- Meta content attribute
        "<meta.*refresh",       -- Meta refresh tag
        "expression%(",         -- CSS expression
        "url%(",                -- CSS url()
        "import",               -- CSS @import
        "document%.cookie",     -- JavaScript cookie access
        "document%.write",      -- JavaScript document.write
        "window%.location",     -- JavaScript redirect
        "eval%(",               -- JavaScript eval
        "fromcharcode",         -- String.fromCharCode
        "unescape",             -- JavaScript unescape
        "decodeuri",            -- JavaScript decodeURI
        "<svg.*onload",         -- SVG onload
        "<img.*onerror",        -- Image onerror
        "alert%(",              -- JavaScript alert
        "prompt%(",             -- JavaScript prompt
        "confirm%("             -- JavaScript confirm
    }
    
    for _, pattern in ipairs(xssPatterns) do
        if nameLower:find(pattern) then
            return true
        end
    end
    
    -- Check for angle brackets and potentially dangerous characters
    if nameOriginal:find("[<>]") then
        return true
    end
    
    return false
end

AddEventHandler('playerConnecting', function(pName, pKickReason, pDeferrals)
    local src = source
    local identifiers = GetPlayerIdentifiers(src)
    local steam, license, ip, hwid = "Onbekend", "Onbekend", "Onbekend", "Onbekend"

    local hasCfxLink = false
    for _, id in ipairs(identifiers) do
        if string.match(id, "steam:") then steam = id end
        if string.match(id, "license:") then license = id end
        if string.match(id, "ip:") then ip = id end
        -- Check for CFX account linking identifiers (license2, license3, etc. are only present when account is linked)
        if string.match(id, "license2:") or string.match(id, "license3:") or string.match(id, "license4:") or string.match(id, "license5:") then
            hasCfxLink = true
        end
    end
    
    -- If player doesn't have CFX account linked and the feature is enabled, reject connection
    if Config.RequireCfxLink and not hasCfxLink then
        pDeferrals.done("You must link your CFX account to FiveM before joining this server. Please visit https://cfx.re/link and follow the instructions to link your account.")
        return
    end

    hwid = GetPlayerToken(src, 0) or "Onbekend"

    pDeferrals.defer()
    Wait(1000)

    -- XSS Detection Check
    if Config.Protections['Anti Xss'] and detectXSS(pName) then
        pDeferrals.done("XSS DETECTED please change your user name to join")
        return
    end

    local nameLower = string.lower(pName or "")
    if Config.BlacklistedNames and type(Config.BlacklistedNames) == "table" then
        for i = 1, #Config.BlacklistedNames do
            local w = Config.BlacklistedNames[i]
            if type(w) == "string" and w ~= "" then
                if nameLower:find(string.lower(w), 1, true) then
                    pDeferrals.done("Your name contains a blacklisted word. Change your name to join.")
                    return
                end
            end
        end
    end

    if Config.Protections['Anti Spoof'] then
        local endpoint = GetPlayerEndpoint(src)
        local tokenCount = GetNumPlayerTokens(src)
        local tokens = {}
        for i = 0, tokenCount - 1 do
            tokens[#tokens+1] = GetPlayerToken(src, i)
        end
        local tokenFingerprint = table.concat(tokens, "|")

        local function isPrivateIP(ipaddr)
            if not ipaddr then return true end
            if ipaddr:match("^10%.") then return true end
            if ipaddr:match("^127%.") then return true end
            if ipaddr:match("^192%.168%.") then return true end
            local a,b = ipaddr:match("^(%d+)%.(%d+)")
            a = tonumber(a); b = tonumber(b)
            if a == 172 and b and b >= 16 and b <= 31 then return true end
            return false
        end

        local flags = 0
        local spoofReasons = {}

        -- 1. Check for basic identifier presence
        if (Config.SpoofDetection and Config.SpoofDetection.RequireLicense) and license == "Onbekend" then 
            flags = flags + 1 
            table.insert(spoofReasons, "Missing License")
        end
        if (Config.SpoofDetection and Config.SpoofDetection.RequireSteam) and steam == "Onbekend" then 
            flags = flags + 1 
            table.insert(spoofReasons, "Missing Steam")
        end

        -- 2. Deep Token Analysis (Powerful like Electron AC)
        local minTokens = (Config.SpoofDetection and Config.SpoofDetection.MinTokens) or 3
        if tokenCount < minTokens then 
            flags = flags + 2 -- High weight for low token count
            table.insert(spoofReasons, "Suspicious Token Count (" .. tokenCount .. ")")
        end

        local allowPrivate = (Config.SpoofDetection and Config.SpoofDetection.AllowPrivateIPs) ~= false
        if (not allowPrivate) and isPrivateIP(endpoint) then 
            flags = flags + 1 
            table.insert(spoofReasons, "Private IP Detected")
        end

        -- 3. Persistent Fingerprinting & Token Recycling Detection
        _G.__fingerprints = _G.__fingerprints or {}
        _G.__tokenHistory = _G.__tokenHistory or {} -- Maps fingerprint -> license
        _G.__ipHistory = _G.__ipHistory or {} -- Maps fingerprint -> last IP

        if tokenFingerprint ~= "" then
            -- Token Recycling: Same fingerprint used by multiple licenses
            if _G.__tokenHistory[tokenFingerprint] and _G.__tokenHistory[tokenFingerprint] ~= license then
                flags = flags + 2
                table.insert(spoofReasons, "Token Recycling Detected (Fingerprint match with different license)")
            else
                _G.__tokenHistory[tokenFingerprint] = license
            end

            -- IP Consistency: Check if IP changed drastically for this fingerprint
            if Config.SpoofDetection.CheckIPConsistency and _G.__ipHistory[tokenFingerprint] then
                if _G.__ipHistory[tokenFingerprint] ~= endpoint then
                    -- Simple IP mismatch check (can be expanded to subnet check)
                    -- For now, we just log it as suspicious
                    -- table.insert(spoofReasons, "IP Inconsistency Detected")
                end
            end
            _G.__ipHistory[tokenFingerprint] = endpoint

            -- Generic fingerprint collision
            if _G.__fingerprints[tokenFingerprint] and _G.__fingerprints[tokenFingerprint] ~= src then
                -- This session collision
                flags = flags + 1
                table.insert(spoofReasons, "Fingerprint Collision (Multiple sessions)")
            else
                _G.__fingerprints[tokenFingerprint] = src
            end
        end

        -- 4. Advanced: Check for "Known Spoofing Tokens" (Static signatures)
        -- Many spoofers use specific hardcoded tokens
        local blacklistedTokens = {
            "0000000000000000000000000000000000000000", -- Example null token
            -- Add known spoofing tokens here
        }
        for _, t in ipairs(tokens) do
            for _, bl in ipairs(blacklistedTokens) do
                if t == bl then
                    flags = flags + 3
                    table.insert(spoofReasons, "Blacklisted Token Detected")
                    break
                end
            end
        end

        local minFlags = (Config.SpoofDetection and Config.SpoofDetection.MinFlagsToBan) or 2
        if flags >= minFlags then
            local reasonStr = table.concat(spoofReasons, ", ")
            banPlayertrigger(src, "Identifier Spoofing Detected: " .. reasonStr, "SPOOF-")
            pDeferrals.done("Connection blocked due to identifier spoofing detection (" .. reasonStr .. ").")
            return
        end
    end

    local bansFile = LoadResourceFile(GetCurrentResourceName(), "html/ban.json")
    if not bansFile then
        pDeferrals.done("[ERROR] Unable to load bans.json.")
        return
    end

    local bans = json.decode(bansFile)
    if not bans then
        pDeferrals.done("[ERROR] Failed to decode bans.json.")
        return
    end

    local isBanned = false
    local banReason = "Onbekende reden"
    local banId = "0000"
    for _, ban in ipairs(bans) do
        local matches = 0
        if ban.steam and ban.steam == steam then matches = matches + 1 end
        if ban.license and ban.license == license then matches = matches + 1 end
        if ban.license2 and ban.license2 == (function()
            for _, id in ipairs(identifiers) do if id:find("license2:") then return id end end
            return "Onbekend"
        end)() then matches = matches + 1 end
        if ban.license3 and ban.license3 == (function()
