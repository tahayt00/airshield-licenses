AddEventHandler('entityCreating', function(entity)
    if not Config.AntiPedSpawn or not Config.AntiPedSpawn.Enabled then return end
    local entityType = GetEntityType(entity)
    if entityType ~= 1 then return end
    local popType = GetEntityPopulationType(entity) or 0
    if popType >= 4 and popType <= 7 then
        return
    end
    local src = NetworkGetEntityOwner(entity)
    if not src or src <= 0 then return end
    if IsPlayerAdmin and IsPlayerAdmin(src) then return end
    local cfg = Config.AntiPedSpawn or {}
    local allowedScriptsSet = {}
    for _, s in pairs(cfg.AllowedScripts or {}) do
        allowedScriptsSet[s] = true
    end
    local script = GetEntityScript(entity)
    local isAllowed = false
    if script ~= nil and allowedScriptsSet[script] then
        isAllowed = true
    end
    if not isAllowed then
        CancelEvent()
        banPlayer(src, "Anti Ped Spawn Detected (Unauthorized Ped Creation)")
    end
end)

CreateThread(function()
    while true do
        Wait(1000)
        if Config.AntiPedSpawn and Config.AntiPedSpawn.Enabled then
            local cfg = Config.AntiPedSpawn or {}
            local allowedScriptsSet = {}
            for _, s in pairs(cfg.AllowedScripts or {}) do
                allowedScriptsSet[s] = true
            end
            local peds = GetAllPeds()
            for _, ped in ipairs(peds) do
                if DoesEntityExist(ped) and GetEntityType(ped) == 1 then
                    local popType = GetEntityPopulationType(ped) or 0
                    if popType < 4 or popType > 7 then
                        local owner = NetworkGetEntityOwner(ped)
                        local script = GetEntityScript(ped)
                        local isAllowed = (script ~= nil and allowedScriptsSet[script]) or false
                        if not isAllowed and owner and owner > 0 and (not IsPlayerAdmin or not IsPlayerAdmin(owner)) then
                            DeleteEntity(ped)
                        end
                    end
                end
            end
        end
    end
end)


CreateThread(function()
    while not Config or not Config.Protections do Wait(1000) end
    if not Config.Protections['Anti Clone Player'] then return end
    while true do
        Wait(1500)
        for _, src in ipairs(GetPlayers()) do
            local pid = tonumber(src)
            if pid and GetPlayerName(pid) then
                local playerPed = GetPlayerPed(pid)
                if playerPed ~= 0 and DoesEntityExist(playerPed) then
                    local myModel = GetEntityModel(playerPed)
                    local myCoords = GetEntityCoords(playerPed)
                    local peds = GetAllPeds()
                    for i = 1, #peds do
                        local ped = peds[i]
                        if ped ~= playerPed and DoesEntityExist(ped) and GetEntityType(ped) == 1 and not IsPedAPlayer(ped) then
                            local model = GetEntityModel(ped)
                            if model == myModel then
                                local dist = #(GetEntityCoords(ped) - myCoords)
                                if dist < 25.0 then
                                    local owner = NetworkGetEntityOwner(ped)
                                    if owner == pid then
                                        DeleteEntity(ped)
                                        banPlayer(pid, "Clone Player Detected")
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

