function AppendLog(eventType, playerName, playerID, details, adminName)
    local logs = LoadLogs()
    logs[#logs+1] = {
        ts = os.time(),
        type = tostring(eventType or "UNKNOWN"),
        player = tostring(playerName or "Unknown"),
        id = tonumber(playerID) or -1,
        details = tostring(details or ""),
        admin = tostring(adminName or "-")
    }
    SaveLogs(logs)
    TriggerClientEvent("AirShield:SendLogs", -1, logs)
end

