-- Store player coordinates temporarily to build complete list
local playerCoordsCache = {}

RegisterServerEvent('AirShield:SendPlayerCoords')
AddEventHandler('AirShield:SendPlayerCoords', function(requestingSrc, sourcePlayer, playerData)
    -- Store the player's coordinates in the cache
    if not playerCoordsCache[requestingSrc] then
        playerCoordsCache[requestingSrc] = {data = {}, timeoutSet = false}
    end
    
    -- Add player data to cache
    table.insert(playerCoordsCache[requestingSrc].data, playerData)
    
    -- Check if we have received data from all players
    local allPlayers = GetPlayers()
    if #playerCoordsCache[requestingSrc].data >= #allPlayers then
        -- Send complete player list with coordinates to requesting client
        TriggerClientEvent('AirShield:SendPlayersPlaceData', requestingSrc, playerCoordsCache[requestingSrc].data)
        -- Clear the cache for this request
        playerCoordsCache[requestingSrc] = nil
    else
        -- Set a timeout to send whatever data we have if not all players respond
        if not playerCoordsCache[requestingSrc].timeoutSet then
            playerCoordsCache[requestingSrc].timeoutSet = true
            SetTimeout(2000, function() -- 2 second timeout
                if playerCoordsCache[requestingSrc] then
                    TriggerClientEvent('AirShield:SendPlayersPlaceData', requestingSrc, playerCoordsCache[requestingSrc].data)
                    playerCoordsCache[requestingSrc] = nil
                end
            end)
        end
    end
end)

