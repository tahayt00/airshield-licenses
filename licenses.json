-- Function to detect when clients are hooking TriggerServerEvent to block AC communication
RegisterNetEvent('AirShield:triggerCheck')
AddEventHandler('AirShield:triggerCheck', function(triggerName, args)
    local src = source
    
    if not src or src == 0 then
        return
    end
    
    -- Check for suspicious trigger patterns that match hex menu techniques
    local triggerLower = string.lower(triggerName or '')
    
    -- Exclude AirShield's own internal events
    if triggerLower:find('airshield:') then
        return  -- Don't check AirShield's own events
    end
    
    -- Common patterns used by hex menu to block AC communication
    -- Only flag if it's NOT an AirShield event and contains suspicious keywords
    if (triggerLower:find('reaper') or triggerLower:find('detect') or 
        triggerLower:find('report') or triggerLower:find('violation') or 
        triggerLower:find('validate') or triggerLower:find('ban') or 
        triggerLower:find('kick') or triggerLower:find('log')) and
       not triggerLower:find('airshield') then
        
        -- This indicates the client is testing or attempting to block AC communication
        banPlayer(src, 'TriggerServerEvent Hooking Detected - Attempting to block anti-cheat communication')
        return
    end
    
    -- Additional checks for other suspicious patterns
    if (triggerLower:find('anticheat') or triggerLower:find('ac_') or 
        triggerLower:find('security')) and
       not triggerLower:find('airshield') then
        
        banPlayer(src, 'Anti-Cheat Communication Interference Detected')
        return
    end
end)

